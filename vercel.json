{
    "rewrites": [
        {
            "source": "/participant/:code",
            "destination": "/api/index.js"
        },
        {
            "source": "/session/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/events/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/ema",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/public/index.html"
        }
    ]
}