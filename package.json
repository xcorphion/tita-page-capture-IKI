{
  "name": "minimalist-writing-study",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Xcorphion_Platform",
    "Research_System",
    "packages/*"
  ],
  "description": "Monorepo for Xcorphion Platform and Research System",
  "main": "server.js",
  "scripts": {
    "dev:platform": "npm run dev -w @xcorphion/platform",
    "dev:research": "npm run dev -w @xcorphion/research",
    "build:platform": "npm run build -w @xcorphion/platform",
    "build:research": "npm run build -w @xcorphion/research",
    "build": "npm run build:research",
    "invite": "node Research_System/scripts/invite.js"
  },
  "dependencies": {
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "@tailwindcss/postcss": "^4.2.4",
    "@vitejs/plugin-react": "^4.3.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "d3-dsv": "^3.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.5",
    "lucide-react": "^0.460.0",
    "mongodb": "^7.2.0",
    "next": "14.2.4",
    "plotly.js": "^3.5.1",
    "react-hook-form": "^7.53.2",
    "react-intersection-observer": "^9.13.1",
    "react-plotly.js": "^2.6.0",
    "react-quill": "^2.0.0",
    "tailwindcss": "^4.2.4",
    "three": "^0.170.0",
    "vite": "^5.4.11"
  }
}